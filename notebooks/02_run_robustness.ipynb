{"cells":[{"cell_type":"code","metadata":{"trusted":true},"source":["# Install dependencies\n","!pip install -q -r ../requirements.txt\n","\n","import os\n","import sys\n","sys.path.append(os.path.abspath(\"../src\"))\n","\n","from run_robustness import main as run_robustness_main\n","\n","print(\"Environment ready.\")"],"outputs":[],"execution_count":null},{"cell_type":"code","metadata":{},"source":["# Configure paths and backends\n","\n","data_dir = os.path.abspath(\"../data/test\")\n","out_dir = os.path.abspath(\"../results\")\n","backends = \"pytesseract,easyocr\"  # add \",trocr\" if enabled and available\n","\n","print(\"Data dir:\", data_dir)\n","print(\"Out dir:\", out_dir)\n","print(\"Backends:\", backends)"],"outputs":[],"execution_count":null},{"cell_type":"code","metadata":{},"source":["# Optional: generate synthetic data if none exists yet\n","\n","if not any(name.endswith((".png", ".jpg", ".jpeg")) for name in os.listdir(data_dir)):\n","    from generate_synthetic_data import create_synthetic_dataset\n","\n","    os.makedirs(data_dir, exist_ok=True)\n","    create_synthetic_dataset(out_dir=data_dir, num_samples=20, seed=42)\n","    print(\"Generated synthetic demo set in\", data_dir)\n","else:\n","    print(\"Using existing data in\", data_dir)"],"outputs":[],"execution_count":null},{"cell_type":"code","metadata":{},"source":["# Run robustness experiment (this may take a few minutes depending on data size and OCR backends)\n","\n","argv = [\n","    \"--data\", data_dir,\n","    \"--out\", out_dir,\n","    \"--backends\", backends,\n","]\n","\n","run_robustness_main(argv)\n","print(\"Done.\")"],"outputs":[],"execution_count":null},{"cell_type":"code","metadata":{},"source":["# Inspect results\n","\n","import pandas as pd\n","\n","metrics_path = os.path.join(out_dir, \"metrics_summary.csv\")\n","df = pd.read_csv(metrics_path)\n","display(df.head())\n","\n","agg_path = os.path.join(out_dir, \"aggregated_metrics.csv\")\n","agg = pd.read_csv(agg_path)\n","display(agg)"],"outputs":[],"execution_count":null}],"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.x"}},"nbformat":4,"nbformat_minor":5}

